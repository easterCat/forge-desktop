{
  "name": "forge-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "plugins": "scripts/plugins/index.mjs"
  },
  "description": "Forge - Manage AI tool configurations",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "tauri:dev:win": "cmd /c \"\"C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\VC\\Auxiliary\\Build\\vcvarsall.bat\" x64 >nul 2>&1 && tauri dev --no-watch\"",
    "tauri:dev:unix": "tauri dev --no-watch",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "plugins": "node scripts/plugins/index.mjs",
    "plugins:install": "node scripts/plugins/install.mjs",
    "plugins:uninstall": "node scripts/plugins/uninstall.mjs",
    "plugins:list": "node scripts/plugins/list.mjs",
    "plugins:init": "node scripts/plugins/init.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^22.15.18",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.12"
  }
}
